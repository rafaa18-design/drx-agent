# =============================================================================
# DRX ADVOGADOS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git
# =============================================================================

# =============================================================================
# IDENTIDADE DO MÓDULO
# =============================================================================
MODULE_ID=drx-advogados
MODULE_VERSION=1.0.0
MODULE_DESCRIPTION=Agente IA DRX Advogados
AGENT_NAME=dra-ana

# =============================================================================
# Authentication (Agno JWT)
# =============================================================================
AUTH_ENABLED=true
# REQUIRED: Set a strong secret for JWT token signing (min 32 chars recommended)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# User credentials for /auth/login endpoint (JSON format)
# SECURITY: Use bcrypt hashes in production!
# Generate hash: python -c "from app.auth import hash_password; print(hash_password('your-password'))"
#
# Development (plain text - NOT for production):
AUTH_USERS={"admin": "admin123", "user": "user123"}
#
# Production (bcrypt hashes):
# AUTH_USERS={"admin": "$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/X4.G4z.P8Gg5.x5Oy"}

# Scopes required to create tokens via /auth/token (admin endpoint)
AUTH_ADMIN_SCOPES=["admin", "tokens:create"]

# =============================================================================
# Model Configuration
# =============================================================================
# Provider: 'anthropic', 'openai', 'vertexai'
MODEL_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# Anthropic API (when MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API (when MODEL_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Vertex AI - Google Cloud (when MODEL_PROVIDER=vertexai)
# For Vertex AI, you need:
# 1. A Google Cloud project with Vertex AI API enabled
# 2. A service account with Vertex AI User role
# 3. Service account JSON key file
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-east5
# Path to service account JSON file (set this as env var or mount in Docker)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Vertex AI Claude model IDs:
# - claude-sonnet-4@20250514
# - claude-3-5-sonnet-v2@20241022

# =============================================================================
# Agent Behavior
# =============================================================================
AGENT_PROMPT_NAME=agent-instructions
# Use specific version (integer) or leave empty for latest
AGENT_PROMPT_VERSION=
# Label to fetch (e.g., 'production', 'staging')
AGENT_PROMPT_LABEL=production
AGENT_INSTRUCTIONS_FALLBACK=Você é a Dra. Ana, assistente virtual da DRX Advogados. Atendo clientes no WhatsApp, faço triagem de casos e agendar consultas com os advogados.
AGENT_DESCRIPTION=Assistente virtual da DRX Advogados especializada em atendimento jurídico-comercial.

MAX_TURNS=10
NUM_HISTORY_RUNS=2

# Memory Consolidation (LLM-driven)
MEMORY_CONSOLIDATION_ENABLED=true
MEMORY_WINDOW=20
MEMORY_CONSOLIDATION_MODEL=claude-haiku-4-5-20251001
MEMORY_CONSOLIDATION_MAX_TOKENS=1024
TOOL_OUTPUT_MAX_CHARS=500

# Model Optimization
CACHE_SYSTEM_PROMPT=true

# =============================================================================
# Storage Configuration
# =============================================================================
# Redis (required for session state and caching)
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=3600
PROMPT_REDIS_KEY=agent:prompt:current
PROMPT_REDIS_TTL=0

# PostgreSQL — banco principal do CRM
# Após instalar o PostgreSQL, crie o banco com:
#   psql -U postgres -c "CREATE DATABASE drx_db;"
DATABASE_URL=postgresql+asyncpg://postgres:sua_senha@localhost:5432/drx_db

# =============================================================================
# WHATSAPP — Evolution API (rodando em servidor Linux)
# =============================================================================
EVOLUTION_API_URL=http://SEU_SERVIDOR:8080
EVOLUTION_API_KEY=sua_chave_evolution_api
EVOLUTION_INSTANCE_NAME=drx-whatsapp
WHATSAPP_WEBHOOK_SECRET=troque-por-string-aleatoria
ESCALATION_PHONE_NUMBER=+5511999999999

# =============================================================================
# GOOGLE CALENDAR — Service Account
# Baixe o JSON no Google Cloud Console após criar a service account
# =============================================================================
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-service-account.json
GOOGLE_CALENDAR_SUBJECT_EMAIL=advogado@drxadvogados.com.br
LAWYER_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo
APPOINTMENT_DURATION_MINUTES=60
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00

# =============================================================================
# Langfuse Configuration (Observability & Prompt Management)
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
# Webhook signature secret (for validating prompt update webhooks)
LANGFUSE_SIGNATURE_SECRET=

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT: 'json' for production (structured logs), 'text' for development
LOG_FORMAT=text

# CORS (JSON array of allowed origins)
# SECURITY: Configure specific origins for production!
# Default allows localhost only. Examples:
# Development: CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
# Production:  CORS_ORIGINS=["https://app.example.com", "https://admin.example.com"]
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
