# Module Configuration
MODULE_ID=asani-agent-template
MODULE_VERSION=1.0.0
MODULE_DESCRIPTION=Asani AI Agent Template - AgentBench Standard

# Model Configuration
DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Agent Configuration
AGENT_PROMPT_NAME=agent-instructions
AGENT_INSTRUCTIONS_FALLBACK=You are a helpful AI assistant.
MAX_TURNS=10
NUM_HISTORY_RUNS=10
COMPRESS_TOOL_RESULTS=true

# Redis Configuration (session state, cache)
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=3600

# PostgreSQL Configuration (persistent storage)
POSTGRES_URL=postgresql+psycopg://user:password@localhost:5432/agentdb

# Langfuse Configuration (observability & prompt management)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
